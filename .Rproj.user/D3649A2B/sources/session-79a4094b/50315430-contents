# Part 5: Analysis Code for Actual Data

## Non-Inferiority Test

```{r}
#| label: ni-analysis-code
#| eval: false
#| code-fold: false

# =============================================================================
# NON-INFERIORITY TEST FOR COMPREHENSION
# =============================================================================

# Parameters
delta <- 0.05  # Non-inferiority margin
alpha <- 0.05  # One-sided

# Your data (replace with actual values)
n1 <- 150  # Traditional group N
x1 <- 120  # Traditional correct (sum across all items, or use proportions)
n2 <- 150  # Condensed group N
x2 <- 118  # Condensed correct

# Calculate
p1 <- x1 / n1
p2 <- x2 / n2
diff <- p2 - p1
se <- sqrt((p1 * (1 - p1) / n1) + (p2 * (1 - p2) / n2))

z_stat <- (diff + delta) / se
p_value <- 1 - pnorm(z_stat)

ci_lower <- diff - qnorm(1 - alpha) * se
ci_upper <- diff + qnorm(1 - alpha) * se

# Output
cat("Non-Inferiority Test Results\n")
cat("============================\n")
cat(sprintf("Traditional: %.1f%%\n", p1 * 100))
cat(sprintf("Condensed:   %.1f%%\n", p2 * 100))
cat(sprintf("Difference:  %.1f%% [90%% CI: %.1f%% to %.1f%%]\n", 
            diff * 100, ci_lower * 100, ci_upper * 100))
cat(sprintf("Margin:      -%.1f%%\n", delta * 100))
cat(sprintf("P-value:     %.4f (one-sided)\n", p_value))
cat(sprintf("Conclusion:  %s\n", 
            ifelse(ci_lower > -delta, "Non-inferiority demonstrated", 
                   "Non-inferiority NOT demonstrated")))
```

