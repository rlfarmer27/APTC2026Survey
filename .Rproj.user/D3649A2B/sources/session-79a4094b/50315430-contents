## Run Simulation

::: {.callout-note}
Using parallel processing with `r max(1, parallel::detectCores() - 1)` cores.
:::

```{r}
#| label: run-simulation
#| cache: false

results <- data.frame(
  n = integer(),
  power_ecl = numeric(),
  power_accept = numeric(),
  power_comp_ni = numeric(),
  convergence_rate = numeric()
)

start_time <- Sys.time()

for (n in sample_sizes) {
  
  cat(sprintf("Simulating N = %d... ", n))
  
  # Run simulations in parallel
  sim_results <- future_lapply(
    seq_len(n_sims),
    function(sim_id) {
      run_single_sim(sim_id, n, pop_ecl, pop_accept, pop_comp,
                     alpha, ni_margin, ni_alpha)
    },
    future.seed = TRUE
  )
  
  # Combine results
  sim_matrix <- do.call(rbind, sim_results)
  
  # Calculate power
  converged_mask <- sim_matrix[, "converged"] == TRUE
  n_converged <- sum(converged_mask, na.rm = TRUE)
  
  if (n_converged > 0) {
    power_ecl <- mean(sim_matrix[converged_mask, "ecl_sig"], na.rm = TRUE)
    power_accept <- mean(sim_matrix[converged_mask, "accept_sig"], na.rm = TRUE)
    power_comp_ni <- mean(sim_matrix[converged_mask, "comp_ni"], na.rm = TRUE)
  } else {
    power_ecl <- power_accept <- power_comp_ni <- NA
  }
  
  results <- rbind(results, data.frame(
    n = n,
    power_ecl = power_ecl,
    power_accept = power_accept,
    power_comp_ni = power_comp_ni,
    convergence_rate = n_converged / n_sims
  ))
  
  cat(sprintf("ECL=%.2f, Accept=%.2f, Comp(NI)=%.2f (converged: %d/%d)\n",
              power_ecl, power_accept, power_comp_ni, n_converged, n_sims))
}

end_time <- Sys.time()
runtime <- as.numeric(difftime(end_time, start_time, units = "mins"))

plan(sequential)
```

