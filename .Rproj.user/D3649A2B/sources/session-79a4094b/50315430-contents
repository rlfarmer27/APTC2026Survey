# Part 3: Non-Inferiority Sensitivity Analysis

## Effect of True Difference

What if the condensed format is actually slightly worse (but still within the acceptable margin)?

```{r}
#| label: ni-sensitivity-diff
#| fig-width: 10
#| fig-height: 6

#' Analytical power for non-inferiority test
power_ni_analytical <- function(n_per_group, p1, p2, delta, alpha = 0.05) {
  true_diff <- p2 - p1
  
  # Participant-level variance accounts for within-person correlation across items
  # Each participant has a proportion correct (mean of 7 binary items)
  # Variance of participant-level proportion: p(1-p)/n_items + ICC adjustment
  n_items <- 7
  icc <- 0.5  # matches within_person_r in simulation parameters
  
  # Variance of mean proportion score per participant
  # = p(1-p)/n_items * (1 + (n_items - 1) * icc)
  var1 <- (p1 * (1 - p1) / n_items) * (1 + (n_items - 1) * icc)
  var2 <- (p2 * (1 - p2) / n_items) * (1 + (n_items - 1) * icc)
  
  se <- sqrt(var1 / n_per_group + var2 / n_per_group)
  
  z_alpha <- qnorm(1 - alpha)
  z_power <- (true_diff + delta) / se - z_alpha
  pnorm(z_power)
}

# Test different true differences
true_differences <- c(0, -0.01, -0.02, -0.03, -0.04)

sensitivity_diff <- expand.grid(
  n_per_group = seq(50, 300, by = 10),
