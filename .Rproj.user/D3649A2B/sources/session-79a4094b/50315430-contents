#| label: helper-functions

# =============================================================================
# DATA GENERATION FUNCTIONS
# =============================================================================

#' Generate correlated ordinal data (long format)
generate_ordinal_data <- function(n_participants, n_items, effect_size, within_r) {
  
  n_per_group <- n_participants / 2
  condition <- rep(c(0, 1), each = n_per_group)
  
  re_sd <- sqrt(within_r)
  resid_sd <- sqrt(1 - within_r)
  
  participant_effects <- rnorm(n_participants, 0, re_sd)
  
  data_list <- vector("list", n_items)
  
  for (i in seq_len(n_items)) {
    latent <- participant_effects + 
              effect_size * condition + 
              rnorm(n_participants, 0, resid_sd)
    
    thresholds <- qnorm(c(0.05, 0.15, 0.30, 0.50, 0.70, 0.85))
    ordinal_response <- as.numeric(cut(latent, breaks = c(-Inf, thresholds, Inf)))
    
    data_list[[i]] <- data.frame(
      participant = seq_len(n_participants),
      condition = factor(condition),
      item = factor(i),
      response = ordered(ordinal_response, levels = 1:7)
    )
  }
  
  do.call(rbind, data_list)
}


#' Generate comprehension data (binomial, long format)
generate_comp_data <- function(n_participants, n_items, baseline_p, true_diff = 0) {
  
  n_per_group <- n_participants / 2
  condition <- rep(c(0, 1), each = n_per_group)
  
  re_sd <- 0.5
  participant_effects <- rnorm(n_participants, 0, re_sd)
  
  # Control group at baseline, treatment group at baseline + true_diff
  group_p <- ifelse(condition == 0, baseline_p, baseline_p + true_diff)
  baseline_logodds <- qlogis(group_p)
  
  data_list <- vector("list", n_items)
  
  for (i in seq_len(n_items)) {
    logodds <- baseline_logodds + 
               participant_effects + 
               rnorm(n_participants, 0, 0.3)
    
    prob <- plogis(logodds)
    prob <- pmin(pmax(prob, 0.01), 0.99)  # Bound probabilities
    correct <- rbinom(n_participants, 1, prob)
    
    data_list[[i]] <- data.frame(
      participant = seq_len(n_participants),
      condition = factor(condition),
      item = factor(i),
      correct = correct
    )
  }
  
  do.call(rbind, data_list)
}


#' Sample participants from population data
sample_from_population <- function(pop_data, n_sample) {
  
  n_per_group <- n_sample / 2
  
  participants_cond0 <- unique(pop_data$participant[pop_data$condition == 0])
  participants_cond1 <- unique(pop_data$participant[pop_data$condition == 1])
  
  sampled_cond0 <- sample(participants_cond0, n_per_group)
  sampled_cond1 <- sample(participants_cond1, n_per_group)
  sampled_participants <- c(sampled_cond0, sampled_cond1)
  
  sample_data <- pop_data[pop_data$participant %in% sampled_participants, ]
  sample_data$participant <- as.integer(factor(sample_data$participant))
  
  sample_data
}


# =============================================================================
# MODEL FITTING FUNCTIONS
# =============================================================================

#' Fit CLMM for ordinal data
fit_clmm <- function(data) {
  
  tryCatch({
    model <- ordinal::clmm(
      response ~ condition + item + (1 | participant),
      data = data,
      link = "logit"
    )
    
    coef_table <- summary(model)$coefficients
    condition_row <- grep("condition1", rownames(coef_table))
    
    if (length(condition_row) > 0) {
      list(
        p = coef_table[condition_row, "Pr(>|z|)"],
        estimate = coef_table[condition_row, "Estimate"],
        converged = TRUE
      )
    } else {
      list(p = NA_real_, estimate = NA_real_, converged = FALSE)
    }
  }, error = function(e) {
    list(p = NA_real_, estimate = NA_real_, converged = FALSE)
  })
}


#' Non-inferiority test for comprehension
test_noninferiority <- function(data, margin, alpha) {
  
  # Aggregate to GROUP-level totals (not participant means)
  group_stats <- data %>%
    group_by(condition) %>%
    summarise(
      n_correct = sum(correct),
      n_total = n(),
      .groups = "drop"
    )
  
  # Group proportions
  p1 <- group_stats$n_correct[group_stats$condition == 0] / 
        group_stats$n_total[group_stats$condition == 0]
  p2 <- group_stats$n_correct[group_stats$condition == 1] / 
        group_stats$n_total[group_stats$condition == 1]
  
  n1 <- group_stats$n_total[group_stats$condition == 0]
  n2 <- group_stats$n_total[group_stats$condition == 1]
  
  diff <- p2 - p1
  se <- sqrt((p1 * (1 - p1) / n1) + (p2 * (1 - p2) / n2))
  
  z_stat <- (diff + margin) / se
  p_value <- 1 - pnorm(z_stat)
  
  list(
    p = p_value,
    reject_h0 = p_value < alpha,
    diff = diff,
    ci_lower = diff - qnorm(1 - alpha) * se,
    converged = TRUE
  )
}


# =============================================================================
# SIMULATION FUNCTION
# =============================================================================

#' Run a single simulation iteration
run_single_sim <- function(sim_id, n, pop_ecl, pop_accept, pop_comp, 
                           alpha_sup, ni_margin, ni_alpha) {
  
  # Sample from populations
  sample_ecl <- sample_from_population(pop_ecl, n)
  sample_accept <- sample_from_population(pop_accept, n)
  sample_comp <- sample_from_population(pop_comp, n)
  
  # Fit superiority models (ECL, Acceptability)
  ecl_result <- fit_clmm(sample_ecl)
  accept_result <- fit_clmm(sample_accept)
  
  # Non-inferiority test (Comprehension)
  comp_result <- test_noninferiority(sample_comp, ni_margin, ni_alpha)
  
  # Check convergence
  sup_converged <- ecl_result$converged && accept_result$converged
  ni_converged <- comp_result$converged
  
  if (!sup_converged) {
    return(c(ecl_sig = NA, accept_sig = NA, comp_ni = NA, converged = FALSE))
  }
  
  # BH correction for superiority tests only
  p_sup <- c(ecl_result$p, accept_result$p)
  p_adj <- p.adjust(p_sup, method = "BH")
  
  c(
    ecl_sig = p_adj[1] < alpha_sup,
    accept_sig = p_adj[2] < alpha_sup,
    comp_ni = ifelse(ni_converged, comp_result$reject_h0, NA),
    converged = TRUE
  )
}
```

