select(starts_with("ClinicSJActivities_")) %>% select(-contains("TEXT")) %>%
summarise(across(everything(), ~sum(!is.na(.) & . != "0" & . != "", na.rm = TRUE))) %>%
pivot_longer(everything(), names_to = "Variable", values_to = "Count") %>%
mutate(Activity = dei_vars[Variable], Percentage = round(100 * Count / nrow(dat), 1)) %>%
filter(!is.na(Activity)) %>% arrange(desc(Count))
