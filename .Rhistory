fee_wide <- function(vars, service_name) {
dat %>%
select(all_of(vars)) %>%
mutate(across(everything(), as.numeric)) %>%
summarise(
Min_Mean   = round(mean(.data[[vars[1]]], na.rm = TRUE), 2),
Min_Median = round(median(.data[[vars[1]]], na.rm = TRUE), 2),
Max_Mean   = round(mean(.data[[vars[2]]], na.rm = TRUE), 2),
Max_Median = round(median(.data[[vars[2]]], na.rm = TRUE), 2),
Typ_Mean   = round(mean(.data[[vars[3]]], na.rm = TRUE), 2),
Typ_Median = round(median(.data[[vars[3]]], na.rm = TRUE), 2),
Range      = paste0(
dollar(round(min(.data[[vars[1]]], na.rm = TRUE))),
" to ",
dollar(round(max(.data[[vars[2]]], na.rm = TRUE)))
)
) %>%
mutate(Service = service_name) %>%
mutate(across(c(Min_Mean, Min_Median, Max_Mean, Max_Median, Typ_Mean, Typ_Median), dollar))
}
therapy_wide <- fee_wide(
c("ClinicTherapyFees_1", "ClinicTherapyFees_2", "ClinicTherapyFees_3"),
"Therapy"
)
assmnt_wide <- fee_wide(
c("ClinicAssmntFees_1", "ClinicAssmntFees_2", "ClinicAssmntFees_3"),
"Assessment"
)
bind_rows(assmnt_wide, therapy_wide) %>%
select(Service,
Min_Mean, Min_Median,
Max_Mean, Max_Median,
Typ_Mean, Typ_Median,
Range) %>%
kable(
col.names = c("Service",
"Avg", "Median",
"Avg", "Median",
"Avg", "Median",
"Range"),
caption = "Standard Fee Structures"
) %>%
kable_styling(bootstrap_options = c("striped", "hover"), font_size = 16) %>%
add_header_above(c(" " = 1,
"Minimum Fee" = 2,
"Maximum Fee" = 2,
"Typical Fee" = 2,
" " = 1)) %>%
column_spec(1, bold = TRUE)
